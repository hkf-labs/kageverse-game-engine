# ===============================================
# KAGEVERSE GAME ENGINE - ENVIRONMENT VARIABLES
# ===============================================

# --- HTTP API SETTINGS ---
# The base URL of the Kageverse Backend Server API.
# Note: For production, change to the real production server HTTP URL.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# --- WEBSOCKET SETTINGS ---
# The base URL of the Kageverse Realtime WebSocket connection.
# Note: For production, change this to wss://...
VITE_WS_BASE_URL=ws://localhost:8080
# Example production:
# VITE_WS_BASE_URL=wss://kageverse-server.onrender.com

# --- ONBOARDING DATA SOURCE ---
# mock: FE demo mode, no backend required.
# api: call backend onboarding endpoints.
VITE_ONBOARDING_DATA_SOURCE=mock

# --- GAME DEBUG (dev only) ---
# true: lưới world + HUD tọa độ (render / business / tiled) + viền hitbox Arcade tím
VITE_GAME_DEBUG=false

# --- COMBAT ---
# false | 0: không poll POST /characters/:id/combat-tick (tắt quái phản đòn tự động)
# Mặc định bật nếu không set
VITE_COMBAT_TICK_ENABLED=true
