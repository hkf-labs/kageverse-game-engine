# ===============================================
# KAGEVERSE GAME ENGINE - ENVIRONMENT VARIABLES
# ===============================================

# --- HTTP API SETTINGS ---
# The base URL of the Kageverse Backend Server API.
# Note: For production, change to the real production server HTTP URL.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# --- WEBSOCKET SETTINGS ---
# The base URL of the Kageverse Realtime WebSocket connection.
# Note: For production, change this to wss://...
VITE_WS_BASE_URL=ws://localhost:8080
